<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AdminCapturesController">
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="🌊 BlueOcean — Admin" styleClass="navbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬅ Retour" styleClass="nav-btn"
                    onAction="#retour"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding:24;">
            <Label text="🐟 Toutes les captures" styleClass="titre"/>
            <TableView fx:id="tableCaptures" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"
                                 prefWidth="80"/>
                    <TableColumn fx:id="colPecheur" text="ID Pêcheur"
                                 prefWidth="150"/>
                    <TableColumn fx:id="colEspece"  text="Espèce"
                                 prefWidth="250"/>
                    <TableColumn fx:id="colPoids"   text="Poids (kg)"
                                 prefWidth="150"/>
                    <TableColumn fx:id="colDate"    text="Date"
                                 prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>