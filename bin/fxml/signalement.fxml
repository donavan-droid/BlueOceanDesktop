<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.SignalementController">
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="🌊 BlueOcean" styleClass="navbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬅ Retour" styleClass="nav-btn"
                    onAction="#retourDashboard"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding:24;">
            <Label text="⚠️ Signalement" styleClass="titre"/>

            <VBox styleClass="card" spacing="12">
                <Label text="Nouveau signalement" styleClass="sous-titre"/>
                <HBox spacing="12">
                    <ComboBox fx:id="typeCombo" prefWidth="200"
                              promptText="Type de probleme"/>
                    <TextField fx:id="localisationField"
                               promptText="Localisation" prefWidth="250"/>
                </HBox>
                <TextArea fx:id="descriptionArea"
                          promptText="Decrivez le probleme..."
                          prefHeight="80" wrapText="true"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Envoyer le signalement"
                            styleClass="btn-danger"
                            onAction="#envoyerSignalement"/>
                    <Label fx:id="msgLabel" text=""/>
                </HBox>
            </VBox>

            <Label text="Mes signalements" styleClass="sous-titre"/>
            <TableView fx:id="tableSignalements" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colType"        text="Type"
                                 prefWidth="140"/>
                    <TableColumn fx:id="colLocalisation" text="Localisation"
                                 prefWidth="200"/>
                    <TableColumn fx:id="colDescription" text="Description"
                                 prefWidth="320"/>
                    <TableColumn fx:id="colDate"        text="Date"
                                 prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>